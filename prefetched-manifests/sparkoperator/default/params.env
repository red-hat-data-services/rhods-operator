# Default/standalone deployment parameters
# All resources deployed in spark-operator namespace

# Spark Operator image
RELATED_IMAGE_ODH_SPARK_OPERATOR_IMAGE=quay.io/opendatahub/spark-operator:v2.5.1
OPERATOR_VERSION=2.5.1

# Image variables used in deployment YAMLs
SPARK_OPERATOR_CONTROLLER_IMAGE=ghcr.io/kubeflow/spark-operator/controller:2.5.1
SPARK_OPERATOR_WEBHOOK_IMAGE=ghcr.io/kubeflow/spark-operator/controller:2.5.1

# Namespace configuration
OPERATOR_NAMESPACE=spark-operator
